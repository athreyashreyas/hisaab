# Hisaab runs fully local-first with NO env vars. These only enable the optional
# end-to-end-encrypted cloud backup (Supabase). Copy to `.env.local` for dev, or
# set them as Environment Variables in Vercel for production.
#
# Both are safe to expose in the client bundle: the anon key is public by design,
# and Row-Level Security + client-side encryption mean the server only ever holds
# ciphertext scoped to the signed-in user.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
